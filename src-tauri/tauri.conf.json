{
    "productName": "Lotion",
    "version": "0.2.0",
    "identifier": "com.lotion.rs",
    "build": {
        "beforeDevCommand": "",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "",
        "frontendDist": "dist"
    },
    "app": {
        "windows": [
            {
                "title": "Lotion",
                "width": 1200,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "decorations": false,
                "transparent": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "rpm",
            "appimage"
        ],
        "icon": [
            "../legacy-electron/assets/icon.png"
        ],
        "category": "Productivity",
        "shortDescription": "Native Rust client for Notion.so",
        "longDescription": "Lotion is a native Rust desktop client for Notion.so, built with Tauri v2 and Iced. Features Zero-Trust security, LiteBox sandboxing, and custom theming."
    }
}