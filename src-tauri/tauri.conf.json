{
    "productName": "lotion-rs",
    "version": "0.2.4",
    "identifier": "io.lotion-rs.secure.v2",
    "build": {
        "frontendDist": "assets"
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/diegoakanotoperator/lotion-rs/releases/latest/download/latest.json"
            ],
            "dialog": true,
            "pubkey": "RWQhTlzddEshBnJi6I3/4hCBdm7SXccxHwTzheJthapxNSndxGC00LRIY"
        }
    },
    "app": {
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "rpm",
            "appimage",
            "dmg",
            "nsis"
        ],
        "icon": [
            "assets/icon.png",
            "assets/icon.ico",
            "assets/icon.icns"
        ],
        "category": "Productivity",
        "shortDescription": "Native Rust client for Notion.so",
        "longDescription": "lotion-rs is a native Rust desktop client for Notion.so, built with Tauri v2. Features Zero-Trust security, LiteBox sandboxing, and custom theming.",
        "resources": [
            "assets/*",
            "i18n/**/*"
        ]
    }
}